FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir \
    fastapi==0.110.0 \
    uvicorn==0.27.0 \
    redis==5.0.1 \
    torch==2.2.0 \
    numpy==1.26.4 \
    pydantic==2.6.0

COPY src/ ./src/
COPY data/delta/mappings/ ./data/delta/mappings/
COPY data/delta/models/ ./data/delta/models/

EXPOSE 8000
CMD ["uvicorn", "src.api.main:app", "--host", "0.0.0.0", "--port", "8000"]